' ── Domínio (models.py) ───────────────────────────────────────────────────────
class BBox {
  +x1: float
  +y1: float
  +x2: float
  +y2: float
  +area(): float
  +iou(other: BBox): float
}

class DetectedObject {
  +label: str
  +score: float
  +bbox: BBox
  +source: str
  +yoloe_conf: Optional[float]
}

DetectedObject *-- BBox : contém

' ── Schemas Pydantic (schemas.py) ────────────────────────────────────────────
class Prompt {
  +image: str
}

class PromptSys {
  +image: str
  +prompt: str
}

