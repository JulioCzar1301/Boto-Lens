@startuml
!theme plain
left to right direction

skinparam componentStyle rectangle
skinparam backgroundColor #FAFAFA
skinparam ArrowColor #2C3E50
skinparam ActorBorderColor #2C3E50
skinparam ActorBackgroundColor #ECF0F1

title Arquitetura Conceitual - Processamento com Qwen3-VL-8B

actor "Usuário" as User

component "Front-end Servidor" as Frontend
note right of Frontend : Conversão para Base64


component "Cloudflare Túnel" as Tunnel
note right of Tunnel : Conexão Segura

component "FastAPI + Uvicorn" as API
note right of API : Endpoints e Roteamento

component "Back-end AWS" as Backend
note right of Backend : Lógica de Negócio e Validação

component "vLLM Inferência" as Inference
note right of Inference : Execução do Modelo

database "Qwen3-VL-8B" as Model
note right of Model : Modelo de Visão-Idioma

' ===== FORÇAR ORDEM DE ESQUERDA PARA DIREITA =====
User -[hidden]right-> Frontend
Frontend -[hidden]right-> Backend
Backend -[hidden]right-> Tunnel
Tunnel -[hidden]right-> API
API -[hidden]right-> Inference
Inference -[hidden]right-> Model

' ===== FLUXO PRINCIPAL =====
User --> Frontend : 1. Envia imagem
Frontend --> Backend : 2. Imagem Base64
Backend --> Tunnel : 3. Requisição
Tunnel --> API : 4. Processa
API --> Inference : 5. Solicita inferência
Inference --> Model : 6. Consulta
Model --> Inference : 7. JSON com objetos
Inference --> API : 8. Resultado
API --> Tunnel : 9. Resposta
Tunnel --> Backend : 10. Retorno
Backend --> Frontend : 11. Dados
Frontend --> User : 12. Exibe objetos

' ===== RELAÇÕES CONCEITUAIS =====
Tunnel ..> Backend : acesso seguro
API ..> Inference : chamada assíncrona

' ===== NOTAS EXPLICATIVAS =====
note bottom of Model
  <b>Qwen3-VL-8B</b>
  Modelo multimodal
  Visão + Linguagem
  Retorna objetos em JSON
end note

note bottom of Inference
  <b>vLLM</b>
  Otimizado para inferência
  Baixa latência
end note

note bottom of Tunnel
  <b>Cloudflare Tunnel</b>
  Sem exposição de porta pública
  Conexão reversa segura
end note

@enduml