@startuml architecture
!define EXTERNAL #FFE4E1
!define INTERNAL #E1F5FE
!define SERVICE  #FFF9E6

skinparam backgroundColor #FAFAFA
skinparam component {
  BorderColor #0277BD
  BackgroundColor INTERNAL
}

package "Aplicação FastAPI (app/)" {
  component "main.py\n(Endpoints & Pipeline)" as API

  package "schemas.py" {
    component "Prompt\nPromptSys" as Schemas
  }

  package "config.py" {
    component "VLLM_URL / MODEL\nThresholds & Constantes" as Config
  }

  package "services/" {
    component "qwen.py\ncall_qwen, call_verify\ncall_vllm_sequential\nparse_*" as QwenSvc
    component "yoloe.py\nrun_yoloe\nget_yoloe (singleton)" as YoloeSvc
    component "fusion.py\nfuse_by_iou\nserialize_detections" as FusionSvc
  }

  package "utils/" {
    component "image.py\nresize, b64_to_pil\npil_to_b64, draw_*" as ImageUtils
    component "geometry.py\nbbox_area, centrality\niou, containment\nis_foreground\nremove_subparts\ncrop_object" as GeomUtils
  }

  package "models.py" {
    component "BBox\nDetectedObject" as Models
  }

  package "system_instruction.py" {
    component "SYSTEM_INSTRUCTION\nVERIFY_INSTRUCTION\nSEQUENTIAL_INSTRUCTION" as Instructions
  }
}

package "Serviços Externos" {
  component "vLLM Server\nQwen2.5-14B-Instruct" as VLLM <<EXTERNAL>>
  component "YOLOE Model\n(yoloe-11l-seg-pf.pt)" as YoloeModel <<EXTERNAL>>
}

actor "Cliente" as Client

' Fluxo principal
Client     --> API          : POST /detection/fused\n(image: base64)
API        --> Schemas      : valida payload
API        --> Config       : lê thresholds
API        --> ImageUtils   : resize + b64_to_pil
API        --> QwenSvc      : call_qwen (paralelo)
API        --> YoloeSvc     : run_yoloe (paralelo)
QwenSvc    --> Instructions : SYSTEM_INSTRUCTION / VERIFY_INSTRUCTION
QwenSvc    --> VLLM         : POST /v1/chat/completions
VLLM       --> QwenSvc      : JSON com objetos / label+score
YoloeSvc   --> YoloeModel   :